<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9"
    tools:context=".DetailActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F5F7F9"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <View
                android:id="@+id/bgHeader"
                android:layout_width="0dp"
                android:layout_height="230dp"
                android:background="#20B273"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvDetailLokasi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="112dp"
                android:layout_marginEnd="24dp"
                android:text="Memuat Data"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/layoutInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDetailLokasi">

                <TextView
                    android:id="@+id/tvDetailBinId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BIN-ID: -"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#A8D5BA"
                    android:layout_gravity="center"/>

                <TextView
                    android:id="@+id/tvTanggal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kamis, 02 April 2026"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardGrafik"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutInfo">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Rekapitulasi Harian"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="24dp"
                        android:weightSum="7">

                        <androidx.cardview.widget.CardView android:id="@+id/btnSenin" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="3dp" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvSenin" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Sen" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView android:id="@+id/btnSelasa" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="3dp" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvSelasa" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Sel" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView android:id="@+id/btnRabu" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="3dp" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvRabu" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Rab" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView android:id="@+id/btnKamis" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="3dp" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvKamis" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Kam" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView android:id="@+id/btnJumat" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="3dp" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvJumat" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Jum" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView android:id="@+id/btnSabtu" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="3dp" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvSabtu" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Sab" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView android:id="@+id/btnMinggu" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" app:cardBackgroundColor="#F5F7F9" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true"><TextView android:id="@+id/tvMinggu" android:layout_width="match_parent" android:layout_height="match_parent" android:text="Min" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/></androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvTitleLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:text="Riwayat Pantauan"
                android:textColor="#555555"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardGrafik" />

            <LinearLayout
                android:id="@+id/layoutLogContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitleLog">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp" app:cardBackgroundColor="#E8F5E9" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_monitor" app:tint="#20B273" android:layout_gravity="center"/>
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                            <TextView android:id="@+id/tvLogTerbaruStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status: AMAN (0%)" android:textSize="14sp" android:textStyle="bold" android:textColor="#222222"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Perubahan volume terbaru" android:textSize="12sp" android:textColor="#555555" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kini" android:textSize="12sp" android:textColor="#20B273" android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnLihatRiwayat"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="Lihat Riwayat Penuh"
                    android:textColor="#20B273"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:backgroundTint="#E8F5E9"
                    app:cornerRadius="12dp"
                    app:strokeColor="#20B273"
                    app:strokeWidth="1dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardStatusSensor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutLogContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Informasi Sensor Real-time"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_monitor"
                            app:tint="#20B273" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Status Penutup"
                            android:textColor="#555555"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvStatusPenutup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TERTUTUP"
                            android:textColor="#20B273"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_monitor"
                            app:tint="#20B273" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Sensor Luar Bak"
                            android:textColor="#555555"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSensor1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 cm"
                            android:textColor="#222222"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_monitor"
                            app:tint="#20B273" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Sensor Dalam Bak"
                            android:textColor="#555555"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSensor2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 cm"
                            android:textColor="#222222"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerDetailBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#20B273"
        android:elevation="8dp"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Kembali"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detail &amp; Grafik"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBackDetail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBackDetail" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>