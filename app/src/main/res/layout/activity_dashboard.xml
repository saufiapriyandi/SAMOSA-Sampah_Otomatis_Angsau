<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/bgHeader"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="#20B273"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardBackgroundColor="#33FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    app:tint="#FFFFFF" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELAMAT DATANG, KEPALA SEKOLAH"
                    android:textColor="#E0E0E0"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPTD SDN 4 Angsau"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPDATE: 14:30 WIB"
                    android:textColor="#E0E0E0"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <androidx.cardview.widget.CardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/btnProfile"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/btnLogout"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/tombollogouticon"
                        app:tint="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/kotakpencarianicon"
                    app:tint="#FFFFFF"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Cari lokasi tong sampah..."
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="12dp"
                    android:textSize="14sp"
                    android:singleLine="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/bgHeader"
            app:layout_constraintBottom_toBottomOf="@id/bgHeader">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="20dp"
                android:paddingHorizontal="12dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL" android:textSize="11sp" android:textColor="#888888" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textSize="26sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E0E0E0" android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PENUH" android:textSize="11sp" android:textColor="#FF4B4B" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textSize="26sp" android:textColor="#FF4B4B" android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E0E0E0" android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KOSONG" android:textSize="11sp" android:textColor="#20B273" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textSize="26sp" android:textColor="#20B273" android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardLegend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardSummary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="12dp">

                <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#20B273" app:cardElevation="0dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AMAN" android:textSize="11sp" android:layout_marginStart="6dp" android:layout_marginEnd="20dp" android:textColor="#555555" android:textStyle="bold"/>

                <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#FFA500" app:cardElevation="0dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WASPADA" android:textSize="11sp" android:layout_marginStart="6dp" android:layout_marginEnd="20dp" android:textColor="#555555" android:textStyle="bold"/>

                <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#FF4B4B" app:cardElevation="0dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PENUH" android:textSize="11sp" android:layout_marginStart="6dp" android:textColor="#555555" android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/layoutStatusTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/cardLegend">

            <androidx.cardview.widget.CardView
                android:layout_width="6dp"
                android:layout_height="24dp"
                app:cardBackgroundColor="#20B273"
                app:cardCornerRadius="3dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Status Real-time"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222222" />

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A20B273"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONITOR"
                    android:textColor="#20B273"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FF4B4B"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/layoutStatusTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="!"
                        android:textColor="#FF4B4B"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peringatan Sistem!"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TERDAPAT 1 TITIK PEMBUANGAN SAMPAH 100% PENUH. SEGERA TINDAK LANJUTI!"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTempatSampah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/cardWarning"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:listitem="@layout/item_tempat_sampah" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>