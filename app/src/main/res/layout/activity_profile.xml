<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9"
    android:fillViewport="true"
    tools:context=".ProfileActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <View
        android:id="@+id/bgHeader"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="#20B273"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnBackProfile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/cd_back"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/profile_title"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBackProfile"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBackProfile" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnBackProfile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="40dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_profile_icon"
                    android:src="@drawable/ic_profile"
                    app:tint="#20B273" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_role"
                android:textColor="#222222"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_id"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/cd_school_icon"
                    android:src="@drawable/ic_school"
                    app:tint="#AAAAAA"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_institution_label"
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_institution_name"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTutorialProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/profile_tutorial_button"
        android:textAllCaps="false"
        android:textColor="@color/green_dark"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/green_surface"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_monitor"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@color/green_dark"
        app:strokeColor="@color/green_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/cardProfile" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageBinsProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:text="@string/profile_manage_bins_button"
        android:textAllCaps="false"
        android:textColor="@color/green_dark"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/green_surface"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_trash"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@color/green_dark"
        app:strokeColor="@color/green_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/btnTutorialProfile" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReportProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:text="@string/profile_report_button"
        android:textAllCaps="false"
        android:textColor="@color/green_dark"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/green_surface"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_report"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@color/green_dark"
        app:strokeColor="@color/green_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/btnManageBinsProfile" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogoutProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/profile_logout_button"
        android:textAllCaps="false"
        android:textColor="@color/red_warning"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/red_surface"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_logout"
        app:iconPadding="12dp"
        app:iconGravity="textStart"
        app:iconTint="@color/red_warning"
        app:strokeColor="@color/red_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/btnReportProfile" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
