<?xml version="1.0" encoding="utf-8"?>
<!--
   [FIX I-2] Konfigurasi aturan backup — exclude data sensitif dari backup ke Google Drive.
   File ini berlaku untuk Android API < 31 (Android 11 ke bawah).
   Lihat: https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!-- Exclude semua SharedPreferences yang mengandung data sensitif -->
    <exclude domain="sharedpref" path="samosa_secure_prefs.xml"/>
    <exclude domain="sharedpref" path="SamosaNotificationState.xml"/>
    <exclude domain="sharedpref" path="SAMOSA_PREFS.xml"/>
    <!-- Izinkan backup data non-sensitif lainnya -->
    <include domain="sharedpref" path="."/>
</full-backup-content>